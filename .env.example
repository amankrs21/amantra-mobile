# API URL for the backend server.
EXPO_PUBLIC_API_URL=

# API key for the weather service.
EXPO_PUBLIC_WEATHER_API_KEY=

# Google OAuth Client IDs for Android and Web.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
